# phish-game environment configuration
# Copy to .env and fill in real values. Do NOT commit .env.

# --- HTTP server ---
APP_HOST=0.0.0.0
APP_PORT=3706
LOG_FORMAT=json

# --- Postgres (game state only; NOT the phish-vault) ---
# When running via docker compose the host is `postgres` (service name).
PG_HOST=postgres
PG_PORT=5432
PG_DB=phish_game
PG_USER=phish_game
PG_PASSWORD=changeme

# --- mcp-phish read path ---
# Points at the mcp-phish container on the same nix1 host. The game NEVER
# reads phish-vault directly; everything routes through this MCP endpoint.
MCP_PHISH_URL=http://mcp-phish:3705/mcp
MCP_PHISH_TIMEOUT_SECONDS=15

# --- Showtime lock policy ---
# Default lock cutoff for any show: 22:00 ET on the show date. Per-show
# overrides live in the `prediction_locks` table.
DEFAULT_LOCK_TIME_LOCAL=22:00
DEFAULT_LOCK_TZ=America/New_York

# --- Auto-resolve cron ---
# Legacy knob kept for backwards-compat with .env files predating session 2.
RESOLVE_INTERVAL_MINUTES=30
# Inside-container resolver loop interval (seconds). Default 1800 (30 min).
RESOLVER_INTERVAL_SECONDS=1800
# How long after lock_at a show with no setlist gets stamped cancelled.
# Conservative: phish.net's setlist publish can lag overnight. Don't drop
# below 24 hours.
RESOLVER_CANCEL_AFTER_HOURS=72

# --- Session / handle ---
# Anonymous handles get a signed cookie. Phase 4b adds magic-link email.
SESSION_SECRET=replace-me-with-a-long-random-string

# --- Smart-pick assist gate (Phase 4) ---
# Pre-lock: assist disabled (HUMAN-ONLY game). Post-lock + post-resolve:
# assist unlocks for retro analysis. Do NOT flip this to false casually.
ASSIST_PRE_LOCK=false

# --- Predict form show selection (operator override) ---
# When set, the predict form targets this show date (YYYY-MM-DD). When
# unset, the form picks the next future date from mcp__phish__recent_shows.
# Used during dev / Phase 4 testing when no real upcoming show is in the
# corpus.
# ADMIN_SHOW_DATE=2026-06-15
# ADMIN_SHOW_VENUE=Madison Square Garden
# ADMIN_SHOW_LOCATION=New York, NY
